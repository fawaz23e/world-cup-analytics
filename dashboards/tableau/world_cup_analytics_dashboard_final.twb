          <datasources>

    <datasource caption='Matches' inline='true' name='kpi_matches' version='18.1'>
      <connection authentication='auth-none' class='hyper' dbname='Data/world_cup_analytics.hyper' default-settings='yes' schema='Extract' sslmode='' tablename='kpi_matches' username='tableau_internal_user'>
        <relation name='kpi_matches' table='[Extract].[kpi_matches]' type='table' />
      </connection>
      <aliases enabled='yes' />
      <column datatype='string' name='[kpi_label]' role='dimension' type='nominal' />
<column datatype='string' name='[kpi_display]' role='dimension' type='nominal' />
<column aggregation='Avg' datatype='real' name='[kpi_value]' role='measure' type='quantitative' />
<column datatype='integer' name='[sort_order]' role='dimension' type='ordinal' />
      <layout dim-ordering='alphabetic' dim-percentage='0.55' measure-ordering='alphabetic' measure-percentage='0.45' show-structure='true' />
    </datasource>

    <datasource caption='Teams' inline='true' name='kpi_teams' version='18.1'>
