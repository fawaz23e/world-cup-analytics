          <pane id='0'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <encodings>
              <color column='[scorers].[sum:goals:qk]' />
<text column='[scorers].[sum:goals:qk]' />
<tooltip column='[scorers].[none:team:nk]' />
<tooltip column='[scorers].[sum:goals:qk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
                <format attr='mark-labels-cull' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows>[scorers].[none:scorer_label:nk]</rows>
        <cols>[scorers].[sum:goals:qk]</cols>
      </table>
    </worksheet>

