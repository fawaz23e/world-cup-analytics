            <datasource caption='Top Scorers' name='scorers' />
          </datasources>
          <datasource-dependencies datasource='scorers'>
            <column datatype='string' name='[scorer_label]' role='dimension' type='nominal' />
<column datatype='string' name='[team]' role='dimension' type='nominal' />
<column aggregation='Sum' caption='Goals' datatype='integer' name='[goals]' role='measure' type='quantitative' />
<column-instance column='[scorer_label]' derivation='None' name='[none:scorer_label:nk]' pivot='key' type='nominal' />
<column-instance column='[team]' derivation='None' name='[none:team:nk]' pivot='key' type='nominal' />
<column-instance column='[goals]' derivation='Sum' name='[sum:goals:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='worksheet'>
            <format attr='background-color' value='#FFFFFF' />
