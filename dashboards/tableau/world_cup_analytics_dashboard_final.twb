          <worksheets>

    <worksheet name='Matches'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#0B2F4A' fontname='Arial' fontsize='15'>Matches</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Matches' name='kpi_matches' />
          </datasources>
          <datasource-dependencies datasource='kpi_matches'>
            <column datatype='string' name='[kpi_display]' role='dimension' type='nominal' />
<column-instance column='[kpi_display]' derivation='None' name='[none:kpi_display:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='worksheet'>
            <format attr='background-color' value='#FFFFFF' />
            <format attr='display-field-labels' scope='rows' value='false' />
            <format attr='display-field-labels' scope='cols' value='false' />
          </style-rule>
        </style>
        <panes>
          <pane id='0'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Text' />
            <encodings>
              <text column='[kpi_matches].[none:kpi_display:nk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
                <format attr='mark-labels-cull' value='true' />
              </style-rule>
            </style>
          </pane>
        </panes>
        <rows></rows>
        <cols></cols>
      </table>
    </worksheet>

