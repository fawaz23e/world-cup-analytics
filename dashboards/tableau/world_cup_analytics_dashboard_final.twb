<column aggregation='Sum' caption='Total Goals' datatype='integer' name='[total_goals]' role='measure' type='quantitative' />
<column aggregation='Avg' caption='Avg Goals' datatype='real' name='[avg_goals_per_match]' role='measure' type='quantitative' />
      <layout dim-ordering='alphabetic' dim-percentage='0.55' measure-ordering='alphabetic' measure-percentage='0.45' show-structure='true' />
